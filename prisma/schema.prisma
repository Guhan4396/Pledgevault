generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  BRANCH_MANAGER
  LOAN_OFFICER
  ACCOUNTANT
}

enum LoanStatus {
  ACTIVE
  RENEWED
  OVERDUE
  CLOSED
  AUCTION_NOTICE_SENT
  AUCTIONED
}

enum PaymentType {
  INTEREST
  PRINCIPAL
  PARTIAL
  FULL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationType {
  LOAN_CREATED
  PAYMENT_RECEIVED
  MATURITY_REMINDER
  OVERDUE_ALERT
  AUCTION_NOTICE
  CLOSURE_CONFIRMATION
  RENEWAL_REMINDER
}

model Branch {
  id              String   @id @default(cuid())
  name            String
  address         String?
  phone           String?
  billPrefix      String   @default("GL")
  billSequence    Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           UserBranch[]
  customers       Customer[]
  loans           Loan[]
  goldRates       GoldRate[]
  settings        BranchSettings?
}

model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  password        String
  role            UserRole   @default(LOAN_OFFICER)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  branches        UserBranch[]
  auditLogs       AuditLog[]
}

model UserBranch {
  userId          String
  branchId        String
  user            User     @relation(fields: [userId], references: [id])
  branch          Branch   @relation(fields: [branchId], references: [id])

  @@id([userId, branchId])
}

model Customer {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String?
  aadhaar         String?
  pan             String?
  address         String?
  addressProofUrl String?
  reputationScore Int      @default(100)
  branchId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch          Branch   @relation(fields: [branchId], references: [id])
  loans           Loan[]
  notifications   Notification[]

  @@unique([phone, branchId])
  @@index([phone])
  @@index([branchId])
}

model GoldRate {
  id              String   @id @default(cuid())
  ratePerGram     Decimal  @db.Decimal(10, 2)
  purity          String   @default("22K")
  branchId        String
  setBy           String?
  effectiveDate   DateTime @default(now())
  createdAt       DateTime @default(now())

  branch          Branch   @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

model Loan {
  id              String     @id @default(cuid())
  billNumber      String
  customerId      String
  branchId        String
  goldRateId      String?

  grossWeight     Decimal    @db.Decimal(8, 3)
  stoneWeight     Decimal    @db.Decimal(8, 3) @default(0)
  netWeight       Decimal    @db.Decimal(8, 3)
  purity          String     @default("22K")
  goldValue       Decimal    @db.Decimal(12, 2)
  ltvPercent      Decimal    @db.Decimal(5, 2) @default(75)

  principalAmount Decimal    @db.Decimal(12, 2)
  interestRate    Decimal    @db.Decimal(5, 2)
  interestType    String     @default("MONTHLY")
  loanDate        DateTime   @default(now())
  maturityDate    DateTime
  gracePeriodDays Int        @default(7)
  gracePeriodEnd  DateTime

  outstandingPrincipal Decimal @db.Decimal(12, 2)
  accruedInterest      Decimal @db.Decimal(12, 2) @default(0)
  totalPaid            Decimal @db.Decimal(12, 2) @default(0)

  status          LoanStatus @default(ACTIVE)
  notes           String?
  goldRateSnapshot Decimal?  @db.Decimal(10, 2)
  renewalCount    Int        @default(0)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  customer        Customer   @relation(fields: [customerId], references: [id])
  branch          Branch     @relation(fields: [branchId], references: [id])
  ornaments       LoanOrnament[]
  payments        Payment[]
  renewals        Renewal[]
  notifications   Notification[]

  @@unique([billNumber, branchId])
  @@index([customerId])
  @@index([branchId])
  @@index([status])
  @@index([maturityDate])
}

model LoanOrnament {
  id              String   @id @default(cuid())
  loanId          String
  description     String
  grossWeight     Decimal  @db.Decimal(8, 3)
  stoneWeight     Decimal  @db.Decimal(8, 3) @default(0)
  netWeight       Decimal  @db.Decimal(8, 3)
  purity          String   @default("22K")
  photoUrl        String?
  tagNumber       String?

  loan            Loan     @relation(fields: [loanId], references: [id])

  @@index([loanId])
  @@index([tagNumber])
}

model Payment {
  id              String      @id @default(cuid())
  loanId          String
  amount          Decimal     @db.Decimal(12, 2)
  interestPaid    Decimal     @db.Decimal(12, 2) @default(0)
  principalPaid   Decimal     @db.Decimal(12, 2) @default(0)
  paymentType     PaymentType @default(PARTIAL)
  receiptNumber   String?
  paymentDate     DateTime    @default(now())
  notes           String?
  createdAt       DateTime    @default(now())

  loan            Loan        @relation(fields: [loanId], references: [id])

  @@index([loanId])
}

model Renewal {
  id              String   @id @default(cuid())
  loanId          String
  renewalDate     DateTime @default(now())
  previousPrincipal Decimal @db.Decimal(12, 2)
  interestPaid    Decimal  @db.Decimal(12, 2) @default(0)
  interestCompounded Decimal @db.Decimal(12, 2) @default(0)
  newPrincipal    Decimal  @db.Decimal(12, 2)
  newMaturityDate DateTime
  renewalType     String   @default("A")
  notes           String?
  createdAt       DateTime @default(now())

  loan            Loan     @relation(fields: [loanId], references: [id])

  @@index([loanId])
}

model Notification {
  id              String             @id @default(cuid())
  customerId      String?
  loanId          String?
  type            NotificationType
  status          NotificationStatus @default(PENDING)
  message         String
  phone           String?
  retryCount      Int                @default(0)
  sentAt          DateTime?
  failureReason   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  customer        Customer?          @relation(fields: [customerId], references: [id])
  loan            Loan?              @relation(fields: [loanId], references: [id])

  @@index([status])
  @@index([customerId])
  @@index([loanId])
}

model AuditLog {
  id              String   @id @default(cuid())
  userId          String?
  action          String
  entityType      String
  entityId        String
  oldValues       Json?
  newValues       Json?
  ipAddress       String?
  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model BranchSettings {
  id                  String   @id @default(cuid())
  branchId            String   @unique
  businessName        String?
  defaultInterestRate Decimal  @db.Decimal(5, 2) @default(2)
  defaultLtvPercent   Decimal  @db.Decimal(5, 2) @default(75)
  defaultGraceDays    Int      @default(7)
  defaultLoanDays     Int      @default(180)
  receiptHeader       String?
  receiptFooter       String?
  smsEnabled          Boolean  @default(false)
  smsProvider         String?
  smsApiKey           String?
  currency            String   @default("INR")
  language            String   @default("en")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  branch              Branch   @relation(fields: [branchId], references: [id])
}
